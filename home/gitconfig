[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[user]
	name = Brad Bergeron
	email = bergeron.bradley@gmail.com

[credential]
	# git-credential-manager handles GitHub.com, GitHub Enterprise, Bitbucket, Azure DevOps
	# Uses macOS Keychain under the hood — fully compatible with osxkeychain
	# Note: git prepends 'git-credential-' to the helper name, so 'manager' → git-credential-manager
	helper = manager
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager

[core]
	pager = delta
	excludesfile = ~/.gitignore_global
	hooksPath = ~/.config/git/hooks

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[interactive]
	diffFilter = delta --color-only

[pull]
	rebase = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[rebase]
	autoStash = true

[gpg]
	format = openpgp
	program = /opt/homebrew/bin/gpg

[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers

[commit]
	gpgsign = false

[tag]
	gpgSign = false

# Machine-specific overrides (signing key, work email, etc.)
# See ~/.config/git/local.gitconfig — not committed
# Add work-specific credential URLs here (GitHub Enterprise, Bitbucket, etc.)
[include]
	path = ~/.config/git/local.gitconfig

# Work organization 1 repositories — auto-loads org-specific email and signing key
# Must be AFTER [commit] section to override gpgsign setting
# Create ~/.config/git/work1.gitconfig from templates/config/git/work.gitconfig.template
# Example: ~/Code/work1/ could be your primary employer or client
[includeIf "gitdir:~/Code/work1/"]
	path = ~/.config/git/work1.gitconfig

# Work organization 2 repositories — auto-loads org-specific email and signing key
# Create ~/.config/git/work2.gitconfig from templates/config/git/work.gitconfig.template
# Example: ~/Code/work2/ could be a secondary employer or client
[includeIf "gitdir:~/Code/work2/"]
	path = ~/.config/git/work2.gitconfig

# VA.gov repositories — auto-loads VA-specific email and signing key
# Uses bradley.bergeron@va.gov for all repos in ~/Code/va.gov/
[includeIf "gitdir:~/Code/va.gov/"]
	path = ~/.config/git/va.gitconfig

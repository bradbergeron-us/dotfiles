[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[user]
	name = Brad Bergeron
	email = bergeron.bradley@gmail.com

# Machine-specific overrides (signing key, work email, etc.)
# See ~/.config/git/local.gitconfig — not committed
[include]
	path = ~/.config/git/local.gitconfig
[credential]
	helper = osxkeychain

[core]
	pager = delta
	excludesfile = ~/.gitignore_global
	hooksPath = ~/.config/git/hooks

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[interactive]
	diffFilter = delta --color-only

[pull]
	rebase = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[rebase]
	autoStash = true

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers

[commit]
	gpgSign = true

[tag]
	gpgSign = true

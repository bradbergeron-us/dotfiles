[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[user]
	name = Brad Bergeron
	email = bergeron.bradley@gmail.com
[credential]
	helper = osxkeychain

[core]
	pager = delta
	excludesfile = ~/.gitignore_global

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[interactive]
	diffFilter = delta --color-only

[pull]
	rebase = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[rebase]
	autoStash = true
